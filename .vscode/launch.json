{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "android",
      "request": "launch",
      "name": "Android: Launch on localhost:5555 (ADB tunnel)",
      "appSrcRoot": "${workspaceRoot}/app/src/main",
      "adbPort": 5037,
      "deviceId": "127.0.0.1:5555",
      "preLaunchTask": "Android: Remote emulator + connect (localhost:5555)",
      "packageName": "space.u2re.service",
      "launchActivity": "space.u2re.service/.MainActivity"
    },
    {
      "type": "android",
      "request": "attach",
      "name": "Android: Attach to process on localhost:5555",
      "appSrcRoot": "${workspaceRoot}/app/src/main",
      "adbPort": 5037,
      "deviceId": "127.0.0.1:5555",
      "processId": "${command:PickAndroidProcess}"
    }
  ]
}
