{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["deno.window", "deno.ns", "deno.unstable"],
    "strict": true
  },
  "imports": {
    "socket.io-client": "npm:socket.io-client@^4.7.5",
    "websocket": "npm:websocket@^1.0.35"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read --allow-write --unstable main.ts",
    "dev": "deno run --allow-net --allow-env --allow-read --allow-write --unstable --watch main.ts"
  }
}
