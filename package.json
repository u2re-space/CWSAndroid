{
  "name": "space.u2re.cws",
  "version": "1.0.0",
  "description": "CWS is a multi-device synchronization system with encrypted communication, clipboard sharing, and command forwarding capabilities.",
  "scripts": {
    "config:stock:sync": "node ./scripts/sync-stock-config.mjs",
    "config:stock:prepare": "npm run config:stock:sync",
    "build:frontend": "node ./scripts/build-frontend.mjs",
    "build": "npm run config:stock:prepare && ./gradlew :app:assembleCwsDebug",
    "build:all": "npm run config:stock:prepare && ./gradlew :app:assembleCwsDebug :app:testCwsDebugUnitTest :app:lintCwsDebug",
    "dev": "npm run config:stock:prepare && ./gradlew :app:installCwsDebug",
    "dev:cwsp": "npm run config:stock:prepare && npm run build:frontend && ./gradlew :app:installCwspDebug",
    "dev:cws": "npm run config:stock:prepare && ./gradlew :app:installCwsDebug",
    "assemble": "npm run config:stock:prepare && ./gradlew :app:assembleCwsDebug :app:installCwsDebug",
    "assemble:cwsp": "npm run config:stock:prepare && npm run build:frontend && ./gradlew :app:assembleCwspDebug :app:installCwspDebug",
    "assemble:cws": "npm run config:stock:prepare && ./gradlew :app:assembleCwsDebug :app:installCwsDebug",
    "assembly": "npm run assemble",
    "assmble": "npm run assemble",
    "attach": "./gradlew attachDebug",
    "android:devices": "adb devices -l",
    "diag:remote": "node ./scripts/run-remote-diag.mjs",
    "diag:remote:adb": "node ./scripts/run-remote-diag.mjs --adb-only"
  },
  "devDependencies": {
    "@cap-js-community/websocket": ">=1.10.0",
    "@capacitor/android": ">=8.3.0",
    "@capacitor/cli": ">=8.3.0",
    "@capacitor/clipboard": ">=8.0.1",
    "@capacitor/core": ">=8.3.0",
    "@types/node": ">=20.10.0",
    "capacitor-cws-bridge": "file:plugins/capacitor-cws-bridge",
    "tsx": ">=4.7.1",
    "typescript": ">=6.0.0-beta"
  }
}
