{
  "name": "space.u2re.cws",
  "version": "1.0.0",
  "description": "CWS is a multi-device synchronization system with encrypted communication, clipboard sharing, and command forwarding capabilities.",
  "scripts": {
    "build:frontend": "node ./scripts/build-frontend.mjs",
    "build": "./gradlew :app:assembleCwsDebug",
    "build:all": "./gradlew :app:assembleCwsDebug :app:testCwsDebugUnitTest :app:lintCwsDebug",
    "dev": "./gradlew :app:installCwsDebug",
    "dev:cwsp": "npm run build:frontend && ./gradlew :app:installCwspDebug",
    "dev:cws": "./gradlew :app:installCwsDebug",
    "assemble": "./gradlew :app:assembleCwsDebug :app:installCwsDebug",
    "assemble:cwsp": "npm run build:frontend && ./gradlew :app:assembleCwspDebug :app:installCwspDebug",
    "assemble:cws": "./gradlew :app:assembleCwsDebug :app:installCwsDebug",
    "assembly": "npm run assemble",
    "assmble": "npm run assemble",
    "attach": "./gradlew attachDebug",
    "android:devices": "adb devices -l"
  },
  "devDependencies": {
    "@cap-js-community/websocket": ">=1.10.0",
    "@capacitor/android": ">=8.3.0",
    "@capacitor/cli": ">=8.3.0",
    "@capacitor/clipboard": ">=8.0.1",
    "@capacitor/core": ">=8.3.0",
    "@types/node": ">=20.10.0",
    "capacitor-cws-bridge": "file:plugins/capacitor-cws-bridge",
    "socket.io": ">=4.8.3",
    "socket.io-client": ">=4.8.3",
    "tsx": ">=4.7.1",
    "typescript": ">=6.0.0-beta"
  }
}
