{
  "name": "space.u2re.cws",
  "version": "1.0.0",
  "description": "CWS is a multi-device synchronization system with encrypted communication, clipboard sharing, and command forwarding capabilities.",
  "scripts": {
    "build": "./gradlew build",
    "dev": "./gradlew :app:installCwsDebug",
    "dev:cwsp": "./gradlew :app:installCwspDebug",
    "assemble": "./gradlew :app:assembleCwsDebug",
    "assemble:cwsp": "./gradlew :app:assembleCwspDebug",
    "android:devices": "adb devices -l"
  },
  "dependencies": {
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
