#!/data/data/com.termux/files/usr/bin/bash
set -euo pipefail

# Termux URL opener integration:
# - Put this file at: ~/.termux/termux-url-opener
# - chmod +x ~/.termux/termux-url-opener
# - termux-reload-settings
#
# Supported:
# - adb://<ip:port>   -> adb connect <ip:port>
# - ssh://user@host[:port] -> ssh user@host -p port
# - adbssh://<ip:port> -> adb connect <ip:port> via Windows SSH (see env vars below)
# - (optional) route adb:// via Windows over SSH using env vars (see below/README)

VBC_ADB_SSH_ENABLE="${VBC_ADB_SSH_ENABLE:-0}"
VBC_ADB_SSH_TARGET="${VBC_ADB_SSH_TARGET:-U2RE@192.168.0.120}"
VBC_ADB_SSH_PORT="${VBC_ADB_SSH_PORT:-22}"
VBC_ADB_LAST_FILE="${VBC_ADB_LAST_FILE:-$HOME/.vbc_last_adb_addr}"

raw="${1:-}"
raw="${raw//$'\r'/}"

if [[ -z "$raw" ]]; then
  echo "No input." >&2
  exit 2
fi

is_valid_addr() {
  local a="${1:-}" ip port o1 o2 o3 o4

  [[ -n "$a" ]] || return 1
  [[ "$a" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}:[0-9]{1,5}$ ]] || return 1

  ip="${a%:*}"
  port="${a##*:}"
  [[ "$port" =~ ^[0-9]+$ ]] || return 1
  ((port >= 1 && port <= 65535)) || return 1

  IFS='.' read -r o1 o2 o3 o4 <<<"$ip"
  for o in "$o1" "$o2" "$o3" "$o4"; do
    [[ "$o" =~ ^[0-9]+$ ]] || return 1
    ((o >= 0 && o <= 255)) || return 1
  done
}

extract_first_valid_addr() {
  local s="${1:-}" a
  while IFS= read -r a; do
    if is_valid_addr "$a"; then
      printf '%s\n' "$a"
      return 0
    fi
  done < <(echo "$s" | tr -d '\r' | grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}:[0-9]{1,5}' || true)
  return 1
}

load_last_addr() {
  local a=""
  [[ -f "$VBC_ADB_LAST_FILE" ]] || return 1
  a="$(tr -d '\r' < "$VBC_ADB_LAST_FILE" | head -n1 | xargs || true)"
  is_valid_addr "$a" || return 1
  printf '%s\n' "$a"
}

persist_last_addr() {
  local a="${1:-}"
  is_valid_addr "$a" || return 0
  mkdir -p "$(dirname "$VBC_ADB_LAST_FILE")" 2>/dev/null || true
  printf '%s\n' "$a" > "$VBC_ADB_LAST_FILE" 2>/dev/null || true
}

adb_connect_local() {
  local addr="$1"
  if ! command -v adb >/dev/null 2>&1; then
    echo "Missing adb. Install (Termux): pkg install -y android-tools" >&2
    exit 1
  fi
  echo "adb connect $addr"
  adb connect "$addr"
  persist_last_addr "$addr"
}

adb_connect_via_ssh() {
  local addr="$1"
  if ! command -v ssh >/dev/null 2>&1; then
    echo "Missing ssh. Install (Termux): pkg install -y openssh" >&2
    exit 1
  fi
  echo "adb via SSH: ${VBC_ADB_SSH_TARGET}:${VBC_ADB_SSH_PORT}"
  echo "remote: adb connect $addr"
  ssh -p "$VBC_ADB_SSH_PORT" "$VBC_ADB_SSH_TARGET" \
    powershell -NoProfile -Command "adb connect $addr; if (\$LASTEXITCODE -ne 0) { exit \$LASTEXITCODE }; echo ''; adb devices -l"
  persist_last_addr "$addr"
}

if [[ "$raw" =~ ^adbssh:// ]]; then
  addr="$(extract_first_valid_addr "${raw#adbssh://}" || true)"
  if [[ -z "$addr" ]]; then
    addr="$(load_last_addr || true)"
    [[ -n "$addr" ]] || { echo "Invalid adbssh:// address (expected ip:port)." >&2; exit 2; }
    echo "Invalid adbssh:// address; using last saved address: $addr"
  fi
  adb_connect_via_ssh "$addr"
  exit 0
fi

if [[ "$raw" =~ ^adb:// ]]; then
  addr="$(extract_first_valid_addr "${raw#adb://}" || true)"
  if [[ -z "$addr" ]]; then
    addr="$(load_last_addr || true)"
    [[ -n "$addr" ]] || { echo "Invalid adb:// address (expected ip:port)." >&2; exit 2; }
    echo "Invalid adb:// address; using last saved address: $addr"
  fi
  if [[ "$VBC_ADB_SSH_ENABLE" == "1" ]]; then
    adb_connect_via_ssh "$addr"
  else
    adb_connect_local "$addr"
  fi
  exit 0
fi

if [[ "$raw" =~ ^ssh:// ]]; then
  target="${raw#ssh://}"
  port="22"
  # allow ssh://user@host:2222
  if [[ "$target" =~ ^([^/]+):([0-9]+)$ ]]; then
    target="${BASH_REMATCH[1]}"
    port="${BASH_REMATCH[2]}"
  fi
  if ! command -v ssh >/dev/null 2>&1; then
    echo "Missing ssh. Install (Termux): pkg install -y openssh" >&2
    exit 1
  fi
  echo "ssh -p $port $target"
  exec ssh -p "$port" "$target"
fi

# Fallback: let Termux open it normally
if command -v termux-open >/dev/null 2>&1; then
  exec termux-open "$raw"
fi

echo "$raw"
